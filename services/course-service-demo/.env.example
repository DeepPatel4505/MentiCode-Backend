NODE_ENV=development
PORT=3002

DATABASE_URL=postgresql://postgres:postgres@localhost:5433/menticode_courses_db

# Same secret as user-service — tokens signed there are verified here
ACCESS_TOKEN_SECRET=change_me_access_secret_min_32_chars

# user-service base URL (for plan lookups)
USER_SERVICE_URL=http://localhost:8000/api/v1/auth

# Redis — cooldown timers + plan cache
REDIS_URL=redis://localhost:6379
REDIS_PLAN_CACHE_TTL=300

CORS_ORIGIN=http://localhost:5173

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
