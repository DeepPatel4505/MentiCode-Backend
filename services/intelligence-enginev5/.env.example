PORT=5001
NODE_ENV=development

# Database — PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/menticode_aienginev5?schema=public"

# ─── LLM Providers ────────────────────────────────────────────────────────────
# Ordered list: first = primary, rest = fallback
# Complexity routing: high→gemini, medium→groq, low→ollama (falls back if unavailable)
LLM_PROVIDERS=gemini,groq,ollama
LLM_TIMEOUT_MS=30000

# Per-session max cloud API calls (prevents runaway spend)
MAX_CLOUD_CALLS_PER_SESSION=20

# ─── Gemini ───────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# ─── Groq ─────────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ─── Ollama (local) ───────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b
