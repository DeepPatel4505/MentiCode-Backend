              "    ",
              "    jsonData.findings.forEach(function(f) {",
              "        console.log('  - [' + f.severity + '] Line ' + f.line + ': ' + f.issue);",
              "    });",
              "}",
              "",
              "pm.test('Should find SQL injection vulnerability', function () {",
              "    var hasSQLInjection = jsonData.findings.some(f => f.issue.toLowerCase().includes('sql injection'));",
