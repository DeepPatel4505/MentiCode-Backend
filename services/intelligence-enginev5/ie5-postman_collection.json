              "    console.log('✅ Session created:', jsonData.sessionId);",
              "}",
              "",
              "pm.test('Session status is ANALYSING', function () {",
              "    pm.expect(jsonData.status).to.equal('ANALYSING');",
              "});",
              "",
              "pm.test('Language detected as javascript', function () {",
              "    pm.expect(jsonData.language).to.equal('javascript');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"language\": \"javascript\",\n  \"code\": \"function getUserById(userId) {\\n  const query = \\`SELECT * FROM users WHERE id = ${userId}\\`;\\n  return db.query(query);\\n}\"\n}"
        },
        "url": {
